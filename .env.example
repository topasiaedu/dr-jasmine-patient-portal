# App (public origin — must match links in GHL email templates in production).
# On Vercel, set this to your deployment URL (or custom domain) in Production and Preview as needed.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Supabase (https://supabase.com/dashboard)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Patient magic-link cookie (use a long random string; min 32 characters recommended)
COOKIE_SECRET=

# Set to "false" for local HTTP dev so Secure cookies work without HTTPS
PATIENT_COOKIE_SECURE=false

# GoHighLevel API v2 — Private Integration token (Bearer) + location UUID
GHL_API_PRIVATE_TOKEN=
GHL_LOCATION_ID=
